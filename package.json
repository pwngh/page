{
  "name": "@pwngh/page",
  "version": "1.0.13",
  "description": "Page integrations for Remix applications.",
  "author": "Preston Neal",
  "license": "MIT",
  "repository": "https://github.com/pwngh/page.git",
  "type": "module",
  "exports": {
    ".": null,
    "./node": {
      "import": "./dist/es/node/index.js",
      "require": "./dist/cjs/node/index.cjs"
    },
    "./react": {
      "import": "./dist/es/react/index.js",
      "require": "./dist/cjs/react/index.cjs"
    },
    "./types": {
      "types": "./dist/types/types.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "watch": "rollup -c -w",
    "build": "run-s lint bundle build-types",
    "build-storybook": "storybook build",
    "build-types": "tsc --declaration --emitDeclarationOnly --allowJs --outDir dist/types src/shared/types.js",
    "bundle": "rollup -c",
    "test": "node --test \"./test/*.test.js\"",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "pret": "prettier -c .",
    "pret:fix": "prettier -w .",
    "clean": "npx --yes rimraf node_modules package-lock.json dist && mkdir dist",
    "load": "npm install --force --legacy-peer-deps",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "@remix-run/node": ">=2.13.1",
    "@remix-run/react": ">=2.13.1",
    "mysql2": ">=3.9.1",
    "react": ">=18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.25.9",
    "@eslint/compat": "^1.1.1",
    "@remix-run/node": "^2.13.1",
    "@remix-run/react": "^2.13.1",
    "@remix-run/testing": "^2.15.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@storybook/addon-essentials": "^8.4.6",
    "@storybook/addon-links": "^8.4.6",
    "@storybook/addon-styling": "^1.3.7",
    "@storybook/blocks": "^8.4.6",
    "@storybook/builder-webpack5": "^8.4.6",
    "@storybook/react": "^8.4.6",
    "@storybook/react-vite": "^8.4.6",
    "@storybook/react-webpack5": "^8.4.6",
    "@storybook/test": "^8.4.6",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "ajv": "^6.15.0",
    "ajv-keywords": "^3.5.2",
    "autoprefixer": "^10.4.20",
    "babel-loader": "^9.2.1",
    "babel-plugin-pure-annotations": "^0.1.2",
    "babel-plugin-transform-react-remove-prop-types": "^0.4.24",
    "css-loader": "^7.1.2",
    "dotenv": "^16.4.7",
    "eslint": "^8.38.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-hooks-addons": "^0.3.1",
    "globals": "^15.1.0",
    "mysql2": "^3.9.1",
    "npm-run-all": "^4.1.5",
    "os-browserify": "^0.3.0",
    "postcss": "^8.4.49",
    "postcss-loader": "^8.1.1",
    "prettier": "^3.2.5",
    "react": "^18.2.0",
    "react-router-dom": "^7.0.2",
    "rollup": "^4.12.1",
    "storybook": "^8.4.6",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "eslint-plugin-react-hooks": {
      "eslint": "$eslint"
    }
  },
  "keywords": [
    "page",
    "components",
    "builder"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
